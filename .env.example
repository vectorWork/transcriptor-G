# Variables para docker-compose (opcional: hay valores por defecto)

# Credenciales de MongoDB
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=rootpass

# Secreto JWT (CÁMBIALO en producción)
JWT_SECRET=cambia-este-secreto-por-uno-largo-y-aleatorio

# Origen del frontend para CORS (debe coincidir con la URL pública)
CLIENT_ORIGIN=http://localhost:8080

# Cookie segura: true solo si sirves por HTTPS
COOKIE_SECURE=false

# Puerto público del frontend (Nginx)
CLIENT_PORT=8080

# Usuario admin inicial
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin1234*
ADMIN_NOMBRE=Administrador
