# Puerto del servidor API
PORT=4000

# Conexión a MongoDB (usuario/clave deben coincidir con docker-compose.yml)
# MONGO_URI=mongodb://root:rootpass@localhost:27017/transcriptor_gacetas?authSource=admin
MONGO_URI=mongodb://127.0.0.1:27017/transcriptor_gacetas

# Secreto para firmar los JWT (cambiar en producción)
JWT_SECRET=cambia-este-secreto-por-uno-largo-y-aleatorio
JWT_EXPIRES_IN=8h

# Origen permitido del frontend (CORS)
CLIENT_ORIGIN=http://localhost:5173

# Credenciales del usuario admin inicial (seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin1234*
ADMIN_NOMBRE=Administrador

# Entorno
NODE_ENV=development
